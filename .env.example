# Sarvam AI API key — sign up at https://www.sarvam.ai (₹1000 free credits)
# Required for translation. Same-language relay works without it.
#
# You can provide ONE key, or several comma-separated keys for automatic
# fallback (when one key's credits/rate limit are exhausted, the next takes
# over with no redeploy):
#   SARVAM_API_KEY=key_a,key_b,key_c
SARVAM_API_KEY=

# Server port
PORT=3000
