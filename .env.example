# Sarvam AI API key — sign up at https://www.sarvam.ai (₹1000 free credits)
# Required for translation. Same-language relay works without it.
#
# You can provide ONE key, or several comma-separated keys for automatic
# fallback (when one key's credits/rate limit are exhausted, the next takes
# over with no redeploy):
#   SARVAM_API_KEY=key_a,key_b,key_c
SARVAM_API_KEY=

# OpenAI key(s) for the optional GPT realtime engine (gpt-realtime-translate).
# Also comma-separated for fallback. If unset, the GPT engine option is hidden
# and rooms use Sarvam.
OPENAI_API_KEY=

# ── Provider Lab keys (optional) ────────────────────────────────────────────
# For the experiment page (/lab.html) where you mix STT / Translate / TTS to
# compare latency. A provider is hidden in the lab UI until its key is set.
# All support comma-separated fallback like Sarvam.
#   DEEPGRAM_API_KEY=     # Deepgram Nova-3 STT (Hindi/English)
#   ELEVENLABS_API_KEY=   # ElevenLabs Scribe v2 STT + Flash v2.5 TTS
#   CARTESIA_API_KEY=     # Cartesia Sonic TTS
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
# Optional model/voice overrides for the lab:
#   CARTESIA_MODEL_ID=sonic-3
#   CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091
#   ELEVEN_MODEL_ID=eleven_flash_v2_5
#   ELEVEN_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Cost rates (optional — defaults reflect published list pricing) ─────────
#   SARVAM_STT_RATE_PER_MIN=0.5          # ₹30/hour
#   SARVAM_TTS_RATE_PER_1K_CHARS=1.5     # ₹15–30 / 10K chars
#   SARVAM_TRANSLATE_RATE_PER_1K_CHARS=2 # ₹20 / 10K chars
#   SARVAM_CURRENCY=INR
#   OPENAI_RATE_PER_MIN=0.034            # gpt-realtime-translate, USD per audio minute

# ── Sarvam latency tuning (optional) ────────────────────────────────────────
# Lower = more responsive/continuous, but may split phrases earlier.
#   SARVAM_SILENCE_FLUSH_MS=350    # micro-pause (ms) after which we flush the clause
#   SARVAM_MAX_SEGMENT_MS=4000     # force a flush during nonstop speech every N ms
# (GPT realtime has no equivalent knob — the model fixes its own phrase pacing.)

# Server port
PORT=3000
